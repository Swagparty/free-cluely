{
  "name": "mona-live",
  "version": "1.0.0",
  "main": "./dist-electron/main.js",
  "scripts": {
    "clean": "rimraf dist dist-electron",
    "dev": "vite",
    "build": "npm run clean && tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "electron:build": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=production electron .",
    "app:dev": "concurrently \"npm run dev -- --port 5180\" \"wait-on http://localhost:5180 && npm run electron:dev\"",
    "app:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder",
    "watch": "tsc -p electron/tsconfig.json --watch",
    "start": "npm run app:dev",
    "dist": "npm run app:build",
    "dist:win": "npm run build && tsc -p electron/tsconfig.json && electron-builder --win --publish never",
    "dist:mac": "npm run build && tsc -p electron/tsconfig.json && electron-builder --mac --publish never",
    "test": "npm run build:test && playwright test",
    "test:ui": "npm run build:test && playwright test --ui",
    "test:headed": "npm run build:test && playwright test --headed",
    "test:debug": "npm run build:test && playwright test --debug",
    "build:test": "tsc -p electron/tsconfig.json && vite build --mode test"
  },
  "build": {
    "appId": "io.mona-ai.live",
    "productName": "MONA Live",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/png/icon.png",
      "hardenedRuntime": false,
      "notarize": false,
      "artifactName": "MonaLive-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/icon.png",
      "artifactName": "MonaLive-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/",
      "category": "Office"
    },
    "protocols": [
      {
        "name": "MONA Live",
        "schemes": [
          "monalive"
        ]
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "generic",
      "url": "https://api.mona-ai.cloud/mona-live"
    }
  },
  "keywords": [],
  "author": "MONA AI GmbH",
  "license": "Apache-2.0",
  "description": "Real-time recruiter interview assistant",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-builder-squirrel-windows": "^25.1.8",
    "electron-playwright-helpers": "^2.1.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "i18next": "^24.2.2",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "tailwind-merge": "^2.5.4",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.21.5",
    "@esbuild/darwin-x64": "^0.21.5",
    "@rollup/rollup-darwin-arm64": "^4.50.1",
    "@rollup/rollup-darwin-x64": "^4.50.1",
    "electron-audio-loopback": "^1.0.6"
  }
}
